<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!--
  AI日报定时推送任务
  触发时间: 每日 08:00
  执行链路: launchd → 个人助理_V1/scripts/run-ai-daily-report.sh (委托入口)
           → AI-Insight/scripts/run-ai-daily-report.sh → send_ai_daily.py
  注意: 实际加载的plist在 ~/Library/LaunchAgents/ 中，由个人助理_V1统一管理。
        本文件仅作为参考文档，与实际加载版本保持一致。
  安装: cp scripts/com.cf.ai-daily-report.plist ~/Library/LaunchAgents/
        launchctl load ~/Library/LaunchAgents/com.cf.ai-daily-report.plist
-->
<dict>
    <key>Label</key>
    <string>com.cf.ai-daily-report</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/shenlang/Documents/Codeflicker/个人助理_V1/scripts/run-ai-daily-report.sh</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/Users/shenlang/Documents/Codeflicker/个人助理_V1/data/logs/ai-daily-push.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/shenlang/Documents/Codeflicker/个人助理_V1/data/logs/ai-daily-push-error.log</string>
    <key>WorkingDirectory</key>
    <string>/Users/shenlang/Documents/Codeflicker/AI-Insight</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>LANG</key>
        <string>zh_CN.UTF-8</string>
        <key>HOME</key>
        <string>/Users/shenlang</string>
    </dict>
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
